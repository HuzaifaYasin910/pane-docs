              "guides/recording/recording-entire-display",
              "guides/recording/webcam-microphone"
            ]
          },
          {
            "group": "Editing project",
            "pages": [
              "guides/editing-project/aspect-ratio",
              "guides/editing-project/cropping",
              "guides/editing-project/trimming",
